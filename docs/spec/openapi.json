  "components": {
    "securitySchemes": {
      "oAuth2": {
        "type": "oauth2",
        "description": "Azure AD OAuth 2.0. Dynamics 365 Supply Chain Management accepts Bearer tokens acquired against the tenant resource.",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
            "scopes": {
              "https://erp.dynamics.com/.default": "Access Dynamics 365 Supply Chain Management on behalf of the application"
            }
          }
        }
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "A pre-acquired Azure AD access token passed as `Authorization: Bearer <token>`. Useful when the caller already has a token from an external identity flow and wants to skip the client-credentials exchange."
      }
    },
    "parameters": {
      "select": {
        "name": "$select",
        "in": "query",
        "description": "OData `$select` — comma-separated list of properties to include in the response.",
        "required": false,
        "schema": { "type": "string" },
        "x-ballerina-name": "selectFields"
      },
      "filter": {
        "name": "$filter",
        "in": "query",
        "description": "OData `$filter` — expression used to restrict the records returned.",
        "required": false,
        "schema": { "type": "string" },
        "x-ballerina-name": "filter"
      },
      "top": {
        "name": "$top",
        "in": "query",
        "description": "OData `$top` — maximum number of records to return.",
        "required": false,
        "schema": { "type": "integer", "format": "int32", "minimum": 0 },
        "x-ballerina-name": "top"
      },
      "skip": {
        "name": "$skip",
        "in": "query",
        "description": "OData `$skip` — number of records to skip.",
        "required": false,
        "schema": { "type": "integer", "format": "int32", "minimum": 0 },
        "x-ballerina-name": "skip"
      },
      "orderBy": {
        "name": "$orderby",
        "in": "query",
        "description": "OData `$orderby` — comma-separated list of properties and directions.",
        "required": false,
        "schema": { "type": "string" },
        "x-ballerina-name": "orderBy"
      },
      "expand": {
        "name": "$expand",
        "in": "query",
        "description": "OData `$expand` — comma-separated list of navigation properties to inline.",
        "required": false,
        "schema": { "type": "string" },
        "x-ballerina-name": "expand"
      },
      "count": {
        "name": "$count",
        "in": "query",
        "description": "OData `$count` — when `true`, the response includes `@odata.count`.",
        "required": false,
        "schema": { "type": "boolean" },
        "x-ballerina-name": "count"
      },
      "crossCompany": {
        "name": "cross-company",
        "in": "query",
        "description": "When `true`, queries span all legal entities the caller has access to instead of the default company.",
        "required": false,
        "schema": { "type": "boolean" },
        "x-ballerina-name": "crossCompany"
      },
      "ifMatch": {
        "name": "If-Match",
        "in": "header",
        "description": "Optimistic concurrency token. Set to the record's `@odata.etag` to ensure the update only succeeds when the record has not changed.",
        "required": false,
        "schema": { "type": "string" }
      },
      "dataAreaId": {
        "name": "dataAreaId",
        "in": "path",
        "required": true,
        "description": "Legal entity identifier (company code).",
        "schema": { "type": "string" }
      },
      "warehouseId": {
        "name": "warehouseId",
        "in": "path",
        "required": true,
        "description": "Warehouse identifier.",
        "schema": { "type": "string" }
      },
      "billOfMaterialsId": {
        "name": "billOfMaterialsId",
        "in": "path",
        "required": true,
        "description": "Bill of materials identifier.",
        "schema": { "type": "string" }
      },
      "productionOrderNumber": {
        "name": "productionOrderNumber",
        "in": "path",
        "required": true,
        "description": "Production order number.",
        "schema": { "type": "string" }
      },
      "transferOrderNumber": {
        "name": "transferOrderNumber",
        "in": "path",
        "required": true,
        "description": "Transfer order number.",
        "schema": { "type": "string" }
      }
    },
    "responses": {
      "ODataError": {
        "description": "OData error response",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ODataError" }
          }
        }
      }
    },
    "schemas": {
      "ODataCollection": {
        "type": "object",
        "description": "Common envelope wrapped around every OData collection response.",
        "properties": {
