{
  "openapi": "3.0.3",
  "info": {
    "title": "Microsoft Dynamics 365 Supply Chain Management",
    "description": "Ballerina connector for a curated subset of the Microsoft Dynamics 365 Supply Chain Management OData REST API. Exposes the warehouse, inventory, BOM, production, transfer, and shipment entities most commonly used in demo scenarios.",
    "version": "1.0.0",
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    },
    "contact": {
      "name": "Ballerina",
      "url": "https://ballerina.io"
    }
  },
  "servers": [
    {
      "url": "https://{tenant}.operations.dynamics.com/data",
      "description": "Dynamics 365 Supply Chain Management tenant",
      "variables": {
        "tenant": {
          "default": "your-org",
          "description": "Tenant-specific subdomain (e.g. contoso, contoso-test)"
        }
      }
    }
  ],
  "security": [
    { "oAuth2": [] },
    { "bearerAuth": [] }
  ],
  "tags": [
    { "name": "Warehouses", "description": "Warehouse master data (Warehouses entity set)" },
    { "name": "Warehouse Locations", "description": "Warehouse location master data" },
    { "name": "Sites", "description": "Inventory sites" },
    { "name": "Item Groups", "description": "Item group reference data" },
    { "name": "Units of Measure", "description": "Global unit-of-measure reference data" },
    { "name": "Bills of Materials", "description": "BOM headers and lines" },
    { "name": "Production Orders", "description": "Production order headers" },
    { "name": "Transfer Orders", "description": "Transfer order headers" },
    { "name": "Inventory", "description": "On-hand inventory and inventory journals" },
    { "name": "Shipments", "description": "Sales shipment (packing slip) headers" }
  ],
  "paths": {
    "/Warehouses": {
      "get": {
        "tags": ["Warehouses"],
        "summary": "List warehouses",
        "description": "Returns a page of warehouse master records.",
        "operationId": "listWarehouses",
        "parameters": [
          { "$ref": "#/components/parameters/select" },
          { "$ref": "#/components/parameters/filter" },
          { "$ref": "#/components/parameters/top" },
          { "$ref": "#/components/parameters/skip" },
          { "$ref": "#/components/parameters/orderBy" },
          { "$ref": "#/components/parameters/expand" },
          { "$ref": "#/components/parameters/count" },
          { "$ref": "#/components/parameters/crossCompany" }
        ],
        "responses": {
          "200": {
            "description": "Warehouse collection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WarehousesCollection" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ODataError" }
        }
      },
      "post": {
        "tags": ["Warehouses"],
        "summary": "Create warehouse",
        "description": "Creates a new warehouse in the specified legal entity.",
        "operationId": "createWarehouse",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Warehouse" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Warehouse created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Warehouse" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ODataError" }
        }
      }
    },
    "/Warehouses(dataAreaId='{dataAreaId}',WarehouseId='{warehouseId}')": {
      "parameters": [
        { "$ref": "#/components/parameters/dataAreaId" },
        { "$ref": "#/components/parameters/warehouseId" }
      ],
      "get": {
        "tags": ["Warehouses"],
        "summary": "Get warehouse",
        "description": "Returns a single warehouse identified by the composite key (`dataAreaId`, `WarehouseId`).",
        "operationId": "getWarehouse",
        "parameters": [
          { "$ref": "#/components/parameters/select" },
          { "$ref": "#/components/parameters/expand" }
        ],
        "responses": {
          "200": {
